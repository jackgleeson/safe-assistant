{
  "permissions": {
    "allow": [],
    "deny": [
      "Read(~/.ssh/*)",
      "Read(**/*.env)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(php *)",
      "Bash(composer *)"
    ],
    "ask": []
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [],
      "allowWrite": [
        "/tmp"
      ]
    }
  }
}
