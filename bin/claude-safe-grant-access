#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/check-platform.sh"

detect_platform

usage() {
    cat <<EOF
Usage: claude-safe-grant-access [OPTIONS] DIR

Grant (or revoke) $RUNNER_USER read/write access to a project directory via
ACLs, and lock down everything else in the parent path so $RUNNER_USER can
only see DIR (and other previously-granted dirs).

How locking works:
  For each ancestor of DIR up to your home directory, the script:
    - Removes world (other) read/write/execute bits on every sibling that
      is not on the path to DIR (so $RUNNER_USER, which is "other" relative
      to your files, cannot read or traverse them).
    - Removes world bits on the ancestor itself and adds an ACL granting
      $RUNNER_USER traverse-only (x) on it.
  Siblings that already have a $RUNNER_USER ACL (previously granted) are
  preserved.

Symlinks pointing outside the locked tree are NOT followed; their targets
keep their original permissions.

Options:
  --revoke           Remove $RUNNER_USER ACLs from DIR. World bits on
                     siblings are NOT restored (you set them manually).
  --no-lock          Only manage ACLs; do not chmod sibling world bits.
                     (Weaker isolation - other world-readable dirs remain
                     visible to $RUNNER_USER.)
  --dry-run          Print what would change without modifying anything.
  -h, --help         Show this help message.

Examples:
  claude-safe-grant-access ~/Projects/myapp
  claude-safe-grant-access --dry-run ~/Projects/myapp
  claude-safe-grant-access --revoke ~/Projects/myapp
EOF
    exit 0
}

REVOKE=false
LOCK_SIBLINGS=true
DRY_RUN=false
TARGET=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --revoke)   REVOKE=true; shift ;;
        --no-lock)  LOCK_SIBLINGS=false; shift ;;
        --dry-run)  DRY_RUN=true; shift ;;
        -h|--help)  usage ;;
        *)          TARGET="$1"; shift ;;
    esac
done

[[ -z "$TARGET" ]] && usage

if [[ ! -d "$TARGET" ]]; then
    fail "Not a directory: $TARGET"
fi

case "$SAFE_ASSISTANT_OS" in
    linux)
        command -v setfacl &>/dev/null \
            || fail "setfacl not found. Install the acl package: sudo apt install acl"
        id "$RUNNER_USER" &>/dev/null \
            || fail "User '$RUNNER_USER' does not exist. Run bin/setup-claude-runner first."
        ;;
    macos)
        dscl . -read "/Users/$RUNNER_USER" &>/dev/null \
            || fail "User '$RUNNER_USER' does not exist. Run bin/setup-claude-runner first."
        ;;
    *)
        fail "claude-safe-grant-access only supports Linux and macOS."
        ;;
esac

TARGET="$(readlink -f "$TARGET")"

INVOKING_USER="$(logname 2>/dev/null || echo "$USER")"

_resolve_home() {
    local u="$1"
    case "$SAFE_ASSISTANT_OS" in
        linux) getent passwd "$u" | cut -d: -f6 ;;
        macos) dscl . -read "/Users/$u" NFSHomeDirectory 2>/dev/null \
                  | awk '/^NFSHomeDirectory:/ {print $2}' ;;
    esac
}

INVOKING_HOME="$(_resolve_home "$INVOKING_USER")"

if [[ -z "$INVOKING_HOME" || ! -d "$INVOKING_HOME" ]]; then
    fail "Cannot determine home directory for $INVOKING_USER"
fi
INVOKING_HOME="$(readlink -f "$INVOKING_HOME")"

case "$TARGET/" in
    "$INVOKING_HOME"/*) ;;
    *) fail "Target $TARGET must be inside $INVOKING_HOME" ;;
esac

# --- Helpers ---

run() {
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "  [dry-run] $*"
    else
        "$@"
    fi
}

has_runner_acl() {
    case "$SAFE_ASSISTANT_OS" in
        linux)
            getfacl -p --absolute-names "$1" 2>/dev/null \
                | grep -qE "^user:$RUNNER_USER:.*[rwx]"
            ;;
        macos)
            ls -lde "$1" 2>/dev/null | grep -qE "^ *[0-9]+: user:$RUNNER_USER "
            ;;
    esac
}

# Apply rwX recursively on $TARGET, with inheritance so new children are
# reachable too.
acl_grant_rw_target() {
    local target="$1"
    case "$SAFE_ASSISTANT_OS" in
        linux)
            run sudo setfacl -R -m "u:$RUNNER_USER:rwX" "$target"
            run sudo setfacl -R -d -m "u:$RUNNER_USER:rwX" "$target"
            ;;
        macos)
            # Inheritance ACE so future children are auto-granted.
            run sudo chmod +a "user:$RUNNER_USER allow list,add_file,search,add_subdirectory,delete_child,readattr,writeattr,readextattr,writeextattr,readsecurity,file_inherit,directory_inherit" "$target"
            # read,write,execute are valid on both files and directories.
            run sudo chmod -R +a "user:$RUNNER_USER allow read,write,execute" "$target"
            ;;
    esac
}

# Apply traverse-only (execute/search) on an ancestor directory.
acl_grant_traverse() {
    local target="$1"
    case "$SAFE_ASSISTANT_OS" in
        linux) run sudo setfacl -m "u:$RUNNER_USER:x" "$target" ;;
        macos) run sudo chmod +a "user:$RUNNER_USER allow execute" "$target" ;;
    esac
}

# Replace any runner ACE with an explicit deny so the runner can't reach
# $TARGET (or its children) via owner/group/other permission bits. A named
# ACL entry takes precedence over 'other' during permission resolution.
acl_revoke_recursive() {
    local target="$1"
    case "$SAFE_ASSISTANT_OS" in
        linux)
            # Overwrite any existing u:runner: entry with empty perms.
            run sudo setfacl -R -m "u:$RUNNER_USER:---" "$target"
            # Default ACL so new children inherit the deny too.
            run sudo setfacl -R -d -m "u:$RUNNER_USER:---" "$target" 2>/dev/null || true
            ;;
        macos)
            # Clear any existing runner ACEs first so we don't stack allows
            # on top of denies (deny wins, but the file gets noisy).
            _revoke_macos_tree "$target"
            # Inheriting deny for future children.
            run sudo chmod +a "user:$RUNNER_USER deny read,write,execute,delete,list,search,add_file,add_subdirectory,delete_child,file_inherit,directory_inherit" "$target"
            # Explicit deny on every existing child.
            run sudo chmod -R +a "user:$RUNNER_USER deny read,write,execute" "$target"
            ;;
    esac
}

_revoke_macos_tree() {
    local target="$1"
    while IFS= read -r -d '' path; do
        local indices
        indices="$(ls -lde "$path" 2>/dev/null \
            | awk -v u="$RUNNER_USER" '
                /^[[:space:]]+[0-9]+:/ {
                    n=$1; sub(/:$/,"",n);
                    if ($0 ~ ("user:" u " ")) print n
                }' \
            | sort -rn)"
        for i in $indices; do
            run sudo chmod -a# "$i" "$path"
        done
    done < <(find "$target" -print0 2>/dev/null)
}

# --- Revoke ---

if [[ "$REVOKE" == "true" ]]; then
    info "Revoking $RUNNER_USER ACLs on $TARGET"
    acl_revoke_recursive "$TARGET"
    ok "Revoked $RUNNER_USER access to $TARGET"
    warn "World permission bits on parent siblings were NOT restored."
    warn "If you want to re-open them, chmod them manually."
    exit 0
fi

# --- Grant ---

# Build (parent, child_on_path) pairs from $INVOKING_HOME down to $TARGET.
parents=()
keeps=()
current="$TARGET"
while [[ "$current" != "$INVOKING_HOME" ]]; do
    parents=("$(dirname "$current")" "${parents[@]+"${parents[@]}"}")
    keeps=("$current" "${keeps[@]+"${keeps[@]}"}")
    current="$(dirname "$current")"
done

info "Granting $RUNNER_USER read/write access to $TARGET"
if [[ "$LOCK_SIBLINGS" == "true" ]]; then
    info "Locking down everything else under $INVOKING_HOME on the path so $RUNNER_USER can only see granted dirs"
fi
[[ "$DRY_RUN" == "true" ]] && info "(dry run - no changes will be made)"

locked=0
preserved=0

for i in "${!parents[@]}"; do
    parent="${parents[$i]}"
    keep="${keeps[$i]}"

    if [[ "$LOCK_SIBLINGS" == "true" ]]; then
        # Lock world bits on every direct child of $parent except $keep
        # and except entries that already have a $RUNNER_USER ACL.
        # Symlinks are skipped: chmod follows them on Linux, which would
        # mutate files outside the locked tree.
        skipped_links=0
        while IFS= read -r child; do
            [[ -z "$child" || "$child" == "$keep" ]] && continue
            if [[ -L "$child" ]]; then
                skipped_links=$((skipped_links + 1))
                continue
            fi
            if has_runner_acl "$child"; then
                preserved=$((preserved + 1))
                continue
            fi
            run sudo chmod o-rwx "$child"
            locked=$((locked + 1))
        done < <(find "$parent" -mindepth 1 -maxdepth 1 2>/dev/null)
        if [[ "$skipped_links" -gt 0 ]]; then
            warn "Skipped $skipped_links symlink(s) under $parent (chmod would follow them)"
        fi

        # Lock the ancestor's own world bits so the runner cannot list it.
        # This includes $INVOKING_HOME - macOS home dirs default to 755
        # (world-readable), which would let the runner enumerate the whole
        # home directory. The traverse ACL entry added below still lets the
        # runner enter the directory without being able to read its contents.
        run sudo chmod o-rwx "$parent"
    fi

    acl_grant_traverse "$parent"
done

acl_grant_rw_target "$TARGET"

ok "Granted $RUNNER_USER read/write access to $TARGET"
if [[ "$LOCK_SIBLINGS" == "true" ]]; then
    info "Locked $locked sibling entries; preserved $preserved already-granted entries"
fi
