#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$PROJECT_DIR/lib"

source "$LIB_DIR/check-platform.sh"

RUNNER_USER="claude-runner"
INVOKING_USER="$(logname 2>/dev/null || echo "$USER")"

# --- Helpers ---

prompt_yn() {
    local question="$1" default="${2:-n}"
    local yn
    if [[ "$default" == "y" ]]; then
        read -rp "$question [Y/n] " yn
        yn="${yn:-y}"
    else
        read -rp "$question [y/N] " yn
        yn="${yn:-n}"
    fi
    [[ "$yn" =~ ^[Yy] ]]
}

# --- Pre-checks ---

if [[ "$(id -u)" -eq 0 ]]; then
    fail "Do not run this script as root. It will use sudo as needed."
fi

detect_platform

if [[ "$LLM_SAFE_OS" != "linux" ]]; then
    fail "claude-runner user isolation is only supported on Linux."
fi

echo ""
echo "claude-runner setup"
echo "==================="
echo ""
info "This script creates a restricted '$RUNNER_USER' user for running Claude Code"
info "with OS-level isolation from your personal files."
echo ""

# --- 1. Create user ---

if id "$RUNNER_USER" &>/dev/null; then
    ok "User '$RUNNER_USER' already exists"
else
    info "Creating user '$RUNNER_USER'..."
    sudo useradd \
        --create-home \
        --home-dir "/home/$RUNNER_USER" \
        --shell /bin/bash \
        --system \
        "$RUNNER_USER"
    sudo passwd -l "$RUNNER_USER" >/dev/null
    ok "Created user '$RUNNER_USER' (no password, login disabled)"
fi

# --- 2. Project access ---

echo ""
info "Project access is granted per-directory via ACLs."
info "For each project you want $RUNNER_USER to access, run:"
echo "    claude-safe-grant-access /path/to/project"
echo ""

# --- 3. Claude binary access ---

CLAUDE_PATH="$(command -v claude 2>/dev/null || true)"

if [[ -z "$CLAUDE_PATH" ]]; then
    warn "claude not found in PATH. Install Claude Code first."
elif [[ "$CLAUDE_PATH" == /usr/local/bin/* || "$CLAUDE_PATH" == /usr/bin/* ]]; then
    ok "claude is in a system-wide location ($CLAUDE_PATH)"
else
    # Claude is under a user home directory. Grant claude-runner traverse-only
    # permission on the directory chain so it can reach the binary.
    # This uses ACLs to target only claude-runner, not all users.
    RESOLVED_PATH="$(readlink -f "$CLAUDE_PATH")"
    RESOLVED_DIR="$(dirname "$RESOLVED_PATH")"

    if ! command -v setfacl &>/dev/null; then
        fail "setfacl not found. Install the acl package: sudo apt install acl"
    fi

    info "claude is at $CLAUDE_PATH (inside your home directory)"
    info "Granting $RUNNER_USER traverse-only access to the claude binary path"

    # Build the list of directories that need traverse permission
    acl_dirs=()
    dir="$RESOLVED_DIR"
    while [[ "$dir" != "/" ]]; do
        acl_dirs=("$dir" "${acl_dirs[@]}")
        dir="$(dirname "$dir")"
    done

    for dir in "${acl_dirs[@]}"; do
        sudo setfacl -m "u:$RUNNER_USER:x" "$dir"
    done
    ok "Granted $RUNNER_USER traverse access (x only) to reach $RESOLVED_PATH"

    # Symlink so claude-runner can find it in PATH
    if [[ ! -L /usr/local/bin/claude ]]; then
        sudo ln -s "$RESOLVED_PATH" /usr/local/bin/claude
        ok "Symlinked /usr/local/bin/claude -> $RESOLVED_PATH"
    else
        existing_target="$(readlink -f /usr/local/bin/claude)"
        if [[ "$existing_target" == "$RESOLVED_PATH" ]]; then
            ok "/usr/local/bin/claude already points to $RESOLVED_PATH"
        else
            sudo ln -sf "$RESOLVED_PATH" /usr/local/bin/claude
            ok "Updated /usr/local/bin/claude -> $RESOLVED_PATH"
        fi
    fi
fi

# --- 4. Config directory ---

RUNNER_HOME="/home/$RUNNER_USER"
RUNNER_CLAUDE_DIR="$RUNNER_HOME/.claude"

if [[ -d "$RUNNER_CLAUDE_DIR" ]]; then
    ok "$RUNNER_CLAUDE_DIR already exists"
else
    info "Creating $RUNNER_CLAUDE_DIR..."
    sudo mkdir -p "$RUNNER_CLAUDE_DIR"
    sudo chown "$RUNNER_USER:$RUNNER_USER" "$RUNNER_CLAUDE_DIR"
    ok "Created $RUNNER_CLAUDE_DIR"
fi

# --- 5. Sync deny paths ---

RUNNER_SETTINGS="$RUNNER_CLAUDE_DIR/settings.json"
info "Syncing deny paths to $RUNNER_SETTINGS..."
# Generate settings to a temp file (as invoking user who can read the repo),
# then copy into the runner's home directory via sudo
tmp_settings="$(mktemp)"
"$SCRIPT_DIR/sync-deny-paths" --settings "$tmp_settings"
sudo cp "$tmp_settings" "$RUNNER_SETTINGS"
sudo chown "$RUNNER_USER:$RUNNER_USER" "$RUNNER_SETTINGS"
rm -f "$tmp_settings"
echo ""

# --- 6. Sudoers rule ---

SUDOERS_FILE="/etc/sudoers.d/claude-runner"

if [[ -f "$SUDOERS_FILE" ]]; then
    ok "Sudoers rule already exists at $SUDOERS_FILE"
else
    echo ""
    info "A sudoers rule lets you run 'sudo -u $RUNNER_USER' without a password."
    if prompt_yn "Create sudoers rule for $INVOKING_USER -> $RUNNER_USER?"; then
        echo "$INVOKING_USER ALL=($RUNNER_USER) NOPASSWD: ALL" | sudo tee "$SUDOERS_FILE" >/dev/null
        sudo chmod 0440 "$SUDOERS_FILE"
        # Validate syntax
        if sudo visudo -cf "$SUDOERS_FILE" &>/dev/null; then
            ok "Created $SUDOERS_FILE"
        else
            sudo rm -f "$SUDOERS_FILE"
            fail "Sudoers syntax check failed. Rule was removed."
        fi
    else
        warn "Skipped. You will need to enter your password each time you use --as-runner."
    fi
fi

# --- 7. Authenticate Claude as runner ---

echo ""
echo "--- Authenticate Claude Code ---"
echo ""

if sudo test -f "$RUNNER_CLAUDE_DIR/.credentials.json"; then
    ok "$RUNNER_USER is already authenticated with Claude Code"
elif [[ -z "${DISPLAY:-}" ]]; then
    warn "No \$DISPLAY detected. Skipping auth - run manually later:"
    echo "    sudo -u $RUNNER_USER claude"
elif ! command -v xhost &>/dev/null; then
    warn "xhost not found. Skipping auth - install x11-xserver-utils, or auth manually:"
    echo "    sudo -u $RUNNER_USER claude"
elif prompt_yn "Run auth now?"; then
    # Grant X access so clipboard paste works
    xhost "+si:localuser:$RUNNER_USER" >/dev/null
    # Revoke on exit, even if the user Ctrl+Cs
    trap "xhost -si:localuser:$RUNNER_USER >/dev/null 2>&1 || true" EXIT

    sudo -u "$RUNNER_USER" \
        DISPLAY="$DISPLAY" \
        claude || true

    xhost "-si:localuser:$RUNNER_USER" >/dev/null
    trap - EXIT
    ok "X access revoked"
else
    echo "  You can authenticate later with:"
    echo "    xhost +si:localuser:$RUNNER_USER"
    echo "    sudo -u $RUNNER_USER claude"
    echo "    xhost -si:localuser:$RUNNER_USER"
fi

# --- Done ---

echo ""
echo "--- Setup complete ---"
echo ""
info "Launch Claude with isolation using:"
echo ""
echo "    claude-safe --as-runner"
echo ""
warn "After Claude Code updates, re-run this script to update the symlink."
echo ""
