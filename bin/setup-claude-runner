#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$PROJECT_DIR/lib"

source "$LIB_DIR/check-platform.sh"

INVOKING_USER="$(logname 2>/dev/null || echo "$USER")"

# --- Helpers ---

prompt_yn() {
    local question="$1" default="${2:-y}"
    local yn
    if [[ "$default" == "y" ]]; then
        read -rp "$question [Y/n] " yn
        yn="${yn:-y}"
    else
        read -rp "$question [y/N] " yn
        yn="${yn:-n}"
    fi
    [[ "$yn" =~ ^[Yy] ]]
}

# --- Pre-checks ---

if [[ "$(id -u)" -eq 0 ]]; then
    fail "Do not run this script as root. It will use sudo as needed."
fi

detect_platform

case "$SAFE_ASSISTANT_OS" in
    linux|macos) ;;
    *) fail "claude-runner user isolation is only supported on Linux and macOS." ;;
esac

RUNNER_HOME="$RUNNER_HOME_BASE/$RUNNER_USER"
RUNNER_CLAUDE_DIR="$RUNNER_HOME/.claude"

echo ""
echo "claude-runner setup"
echo "==================="
echo ""
info "This script creates a restricted '$RUNNER_USER' user for running Claude Code"
info "with OS-level isolation from your personal files."
echo ""

# --- 1. Create user ---

_create_user_linux() {
    sudo useradd \
        --create-home \
        --home-dir "$RUNNER_HOME" \
        --shell /bin/bash \
        --system \
        "$RUNNER_USER"
    sudo passwd -l "$RUNNER_USER" >/dev/null
}

# Lowest free numeric ID in the macOS system range (300-499), for either
# Users/UniqueID or Groups/PrimaryGroupID. System IDs stay out of the normal
# user range and out of the login window.
_next_free_id_macos() {
    local kind="$1" attr="$2" id=300
    local used
    used="$(dscl . -list "/$kind" "$attr" 2>/dev/null | awk '{print $2}' | sort -n)"
    while echo "$used" | grep -qx "$id"; do
        id=$((id + 1))
        [[ $id -ge 500 ]] && return 1
    done
    echo "$id"
}

_create_user_macos() {
    # Dedicated matching group so the runner isn't in `staff` (which is the
    # default primary group for regular users and has read on many dirs).
    if ! dscl . -read "/Groups/$RUNNER_USER" &>/dev/null; then
        local gid
        gid="$(_next_free_id_macos Groups PrimaryGroupID)" \
            || fail "No free GID in system range 300-499"
        info "Creating group '$RUNNER_USER' (GID $gid)"
        sudo dscl . -create "/Groups/$RUNNER_USER"
        sudo dscl . -create "/Groups/$RUNNER_USER" PrimaryGroupID "$gid"
        sudo dscl . -create "/Groups/$RUNNER_USER" RealName "Claude Runner"
        sudo dscl . -create "/Groups/$RUNNER_USER" Password '*'
    fi

    local gid
    gid="$(dscl . -read "/Groups/$RUNNER_USER" PrimaryGroupID | awk '{print $2}')"

    local uid
    uid="$(_next_free_id_macos Users UniqueID)" \
        || fail "No free UID in system range 300-499"

    info "Creating user '$RUNNER_USER' (UID $uid)"
    sudo dscl . -create "/Users/$RUNNER_USER"
    sudo dscl . -create "/Users/$RUNNER_USER" UserShell /bin/bash
    sudo dscl . -create "/Users/$RUNNER_USER" RealName "Claude Runner"
    sudo dscl . -create "/Users/$RUNNER_USER" UniqueID "$uid"
    sudo dscl . -create "/Users/$RUNNER_USER" PrimaryGroupID "$gid"
    sudo dscl . -create "/Users/$RUNNER_USER" NFSHomeDirectory "$RUNNER_HOME"
    sudo dscl . -create "/Users/$RUNNER_USER" Password '*'
    # Hide from the login window.
    sudo dscl . -create "/Users/$RUNNER_USER" IsHidden 1

    sudo mkdir -p "$RUNNER_HOME"
    sudo chown "$RUNNER_USER:$RUNNER_USER" "$RUNNER_HOME"
    sudo chmod 750 "$RUNNER_HOME"
}

_user_exists() {
    case "$SAFE_ASSISTANT_OS" in
        linux) id "$RUNNER_USER" &>/dev/null ;;
        macos) dscl . -read "/Users/$RUNNER_USER" &>/dev/null ;;
    esac
}

if _user_exists; then
    ok "User '$RUNNER_USER' already exists"
else
    info "Creating user '$RUNNER_USER'..."
    if [[ "$SAFE_ASSISTANT_OS" == "macos" ]]; then
        _create_user_macos
    else
        _create_user_linux
    fi
    ok "Created user '$RUNNER_USER' (no password, login disabled)"
fi

# --- 2. Project access ---

echo ""
info "Project access is granted per-directory via ACLs."
info "For each project you want $RUNNER_USER to access, run:"
echo "    claude-safe-grant-access /path/to/project"
echo ""

# --- 3. Claude binary access ---

CLAUDE_PATH="$(command -v claude 2>/dev/null || true)"

# Grant the runner traverse-only (execute) permission on a single directory.
_grant_traverse() {
    local dir="$1"
    if [[ "$SAFE_ASSISTANT_OS" == "macos" ]]; then
        sudo chmod +a "user:$RUNNER_USER allow execute" "$dir" 2>/dev/null || true
    else
        sudo setfacl -m "u:$RUNNER_USER:x" "$dir"
    fi
}

if [[ -z "$CLAUDE_PATH" ]]; then
    warn "claude not found in PATH. Install Claude Code first."
elif [[ "$CLAUDE_PATH" == /usr/local/bin/* || "$CLAUDE_PATH" == /usr/bin/* || "$CLAUDE_PATH" == /opt/homebrew/* ]]; then
    ok "claude is in a system-wide location ($CLAUDE_PATH)"
else
    # Claude is under a user home directory. Grant claude-runner traverse-only
    # permission on the directory chain so it can reach the binary.
    RESOLVED_PATH="$(readlink -f "$CLAUDE_PATH")"
    RESOLVED_DIR="$(dirname "$RESOLVED_PATH")"

    if [[ "$SAFE_ASSISTANT_OS" == "linux" ]] && ! command -v setfacl &>/dev/null; then
        fail "setfacl not found. Install the acl package: sudo apt install acl"
    fi

    info "claude is at $CLAUDE_PATH (inside your home directory)"
    info "Granting $RUNNER_USER traverse-only access to the claude binary path"

    acl_dirs=()
    dir="$RESOLVED_DIR"
    while [[ "$dir" != "/" ]]; do
        acl_dirs=("$dir" "${acl_dirs[@]+"${acl_dirs[@]}"}")
        dir="$(dirname "$dir")"
    done

    for dir in "${acl_dirs[@]}"; do
        _grant_traverse "$dir"
    done
    ok "Granted $RUNNER_USER traverse access (x only) to reach $RESOLVED_PATH"

    # Symlink so claude-runner can find it in PATH.
    if [[ ! -L /usr/local/bin/claude ]]; then
        sudo ln -s "$RESOLVED_PATH" /usr/local/bin/claude
        ok "Symlinked /usr/local/bin/claude -> $RESOLVED_PATH"
    else
        existing_target="$(readlink -f /usr/local/bin/claude)"
        if [[ "$existing_target" == "$RESOLVED_PATH" ]]; then
            ok "/usr/local/bin/claude already points to $RESOLVED_PATH"
        else
            sudo ln -sf "$RESOLVED_PATH" /usr/local/bin/claude
            ok "Updated /usr/local/bin/claude -> $RESOLVED_PATH"
        fi
    fi
fi

# --- 4. Config directory ---

if [[ -d "$RUNNER_CLAUDE_DIR" ]]; then
    ok "$RUNNER_CLAUDE_DIR already exists"
else
    info "Creating $RUNNER_CLAUDE_DIR..."
    sudo mkdir -p "$RUNNER_CLAUDE_DIR"
    sudo chown "$RUNNER_USER:$RUNNER_USER" "$RUNNER_CLAUDE_DIR"
    ok "Created $RUNNER_CLAUDE_DIR"
fi

# --- 5. Git safe.directory ---

# Granted project dirs are owned by the invoking user, so every git
# invocation under $RUNNER_USER hits "dubious ownership" otherwise. The
# runner's ACL grants are the real access boundary, and this setting only
# affects the restricted runner account.
if command -v git &>/dev/null; then
    # Run git from /tmp so getcwd() succeeds for the newly-created runner user,
    # which has no read access to the script's current working directory yet.
    if (cd /tmp && sudo -n -H -u "$RUNNER_USER" git config --global --get-all safe.directory 2>/dev/null) | grep -Fxq '*'; then
        ok "$RUNNER_USER git already trusts granted repos"
    else
        info "Setting safe.directory = * in $RUNNER_USER's gitconfig"
        (cd /tmp && sudo -H -u "$RUNNER_USER" git config --global --add safe.directory '*')
        ok "Set safe.directory = * for $RUNNER_USER"
    fi
else
    warn "git not found; skipping safe.directory setup for $RUNNER_USER"
fi

# --- 6. Sync deny paths ---

RUNNER_SETTINGS="$RUNNER_CLAUDE_DIR/settings.json"
info "Syncing deny paths to $RUNNER_SETTINGS..."
tmp_settings="$(mktemp)"
# Seed with {} so sync-deny-paths has valid JSON to merge into.
echo '{}' > "$tmp_settings"
"$SCRIPT_DIR/sync-deny-paths" --settings "$tmp_settings"
sudo cp "$tmp_settings" "$RUNNER_SETTINGS"
sudo chown "$RUNNER_USER:$RUNNER_USER" "$RUNNER_SETTINGS"
rm -f "$tmp_settings"
echo ""

# --- 7. Copy CLAUDE.md ---

USER_CLAUDE_MD="$HOME/.claude/CLAUDE.md"
RUNNER_CLAUDE_MD="$RUNNER_CLAUDE_DIR/CLAUDE.md"

if [[ -f "$USER_CLAUDE_MD" ]]; then
    info "Copying CLAUDE.md to $RUNNER_CLAUDE_MD..."
    sudo cp "$USER_CLAUDE_MD" "$RUNNER_CLAUDE_MD"
    sudo chown "$RUNNER_USER:$RUNNER_USER" "$RUNNER_CLAUDE_MD"
    ok "Copied CLAUDE.md"
else
    info "No CLAUDE.md at $USER_CLAUDE_MD, skipping"
fi

# --- 8. Sudoers rule ---

SUDOERS_FILE="/etc/sudoers.d/$RUNNER_USER"

if [[ -f "$SUDOERS_FILE" ]]; then
    ok "Sudoers rule already exists at $SUDOERS_FILE"
else
    echo ""
    info "A sudoers rule lets you run 'sudo -u $RUNNER_USER' without a password."
    if prompt_yn "Create sudoers rule for $INVOKING_USER -> $RUNNER_USER?"; then
        echo "$INVOKING_USER ALL=($RUNNER_USER) NOPASSWD: ALL" | sudo tee "$SUDOERS_FILE" >/dev/null
        sudo chmod 0440 "$SUDOERS_FILE"
        if sudo visudo -cf "$SUDOERS_FILE" &>/dev/null; then
            ok "Created $SUDOERS_FILE"
        else
            sudo rm -f "$SUDOERS_FILE"
            fail "Sudoers syntax check failed. Rule was removed."
        fi
    else
        warn "Skipped. You will need to enter your password each time you use claude-safe."
    fi
fi

# --- 9. Authenticate Claude as runner ---

echo ""
echo "--- Authenticate Claude Code ---"
echo ""

_runner_has_credentials() {
    sudo test -f "$RUNNER_CLAUDE_DIR/.credentials.json"
}

if _runner_has_credentials; then
    ok "$RUNNER_USER is already authenticated with Claude Code"
elif [[ "$SAFE_ASSISTANT_OS" == "macos" ]]; then
    # No X11 bridge needed. Claude Code's OAuth prints a URL that opens in the
    # invoking user's default browser; the runner's terminal then accepts the
    # pasted code. So run it inline here - the browser launch happens in the
    # user's GUI session even though `claude` itself runs as $RUNNER_USER.
    info "Launching 'sudo -u $RUNNER_USER -i claude' for OAuth."
    info "When prompted, open the printed URL in your browser, then paste the code back."
    info "Once authenticated, exit Claude Code (Ctrl-C or Ctrl-D) to continue setup."
    if prompt_yn "Run auth now?"; then
        sudo -u "$RUNNER_USER" -i claude || true
    else
        echo "  You can authenticate later with:"
        echo "    sudo -u $RUNNER_USER -i claude"
    fi
elif [[ -z "${DISPLAY:-}" ]]; then
    warn "No \$DISPLAY detected. Skipping auth - run manually later:"
    echo "    sudo -u $RUNNER_USER claude"
elif ! command -v xhost &>/dev/null; then
    warn "xhost not found. Skipping auth - install x11-xserver-utils, or auth manually:"
    echo "    sudo -u $RUNNER_USER claude"
else
    info "Once authenticated, exit Claude Code (Ctrl-C or Ctrl-D) to continue setup."
    if prompt_yn "Run auth now?"; then
        xhost "+si:localuser:$RUNNER_USER" >/dev/null
        trap "xhost -si:localuser:$RUNNER_USER >/dev/null 2>&1 || true" EXIT

        sudo -u "$RUNNER_USER" \
            DISPLAY="$DISPLAY" \
            claude || true

        xhost "-si:localuser:$RUNNER_USER" >/dev/null
        trap - EXIT
        ok "X access revoked"
    else
        echo "  You can authenticate later with:"
        echo "    xhost +si:localuser:$RUNNER_USER"
        echo "    sudo -u $RUNNER_USER claude"
        echo "    xhost -si:localuser:$RUNNER_USER"
    fi
fi

# --- Done ---

echo ""
echo "--- Setup complete ---"
echo ""
warn "After Claude Code updates, re-run this script to update the symlink."
echo ""
