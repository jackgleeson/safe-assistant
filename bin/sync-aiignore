#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$PROJECT_DIR/lib"

source "$LIB_DIR/check-platform.sh"

CONF_FILE="$PROJECT_DIR/deny-paths.conf"
AIIGNORE_DIR="."
DRY_RUN=false

usage() {
    cat <<EOF
Usage: sync-aiignore [OPTIONS]

Read deny-paths.conf and write IDE-embedded assistant ignore files:
  - .aiignore      (generic)
  - .cursorignore  (Cursor)
  - .codeiumignore (Windsurf)

Use this when you work with an IDE-embedded assistant (Cursor, Windsurf,
Copilot, etc.) and want it to honour the same deny list as claude-safe.

Options:
  --conf FILE        Path to deny-paths.conf (default: <project>/deny-paths.conf)
  --dir DIR          Directory to write ignore files into (default: cwd)
  --dry-run          Print what would be written without modifying any files
  -h, --help         Show this help message

Examples:
  sync-aiignore                          # Write ignore files to cwd
  sync-aiignore --dir /path/to/project   # Write ignore files to a project
  sync-aiignore --dry-run                # Preview changes
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --conf)     CONF_FILE="$2"; shift 2 ;;
        --dir)      AIIGNORE_DIR="$2"; shift 2 ;;
        --dry-run)  DRY_RUN=true; shift ;;
        -h|--help)  usage ;;
        *)          fail "Unknown option: $1" ;;
    esac
done

if [[ ! -f "$CONF_FILE" ]]; then
    fail "Config file not found: $CONF_FILE"
fi

if [[ ! -d "$AIIGNORE_DIR" ]]; then
    fail "Target directory does not exist: $AIIGNORE_DIR"
fi

# --- Parse conf file (path entries only; bash: rules do not apply) ---

ignore_patterns=()

while IFS= read -r line; do
    line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" == bash:* ]] && continue
    ignore_patterns+=("$line")
done < "$CONF_FILE"

info "Parsed ${#ignore_patterns[@]} ignore pattern(s) from $CONF_FILE"

# --- Build the managed block (delimited so we can merge with user content) ---

BEGIN_MARKER="# >>> safe-assistant managed block >>>"
END_MARKER="# <<< safe-assistant managed block <<<"

build_managed_block() {
    # $1: newline-separated list of patterns already present in user section (to exclude)
    local user_patterns="$1"
    local block="$BEGIN_MARKER"
    block+=$'\n'"# Generated by safe-assistant from deny-paths.conf"
    block+=$'\n'"# Do not edit between these markers - run: bin/sync-aiignore --dir $(printf '%q' "$AIIGNORE_DIR")"
    local p
    for p in "${ignore_patterns[@]}"; do
        if [[ -n "$user_patterns" ]] && grep -Fxq -- "$p" <<<"$user_patterns"; then
            continue
        fi
        block+=$'\n'"$p"
    done
    block+=$'\n'"$END_MARKER"
    printf '%s' "$block"
}

extract_user_patterns() {
    # Print lines outside the managed block, stripped & non-empty/non-comment
    awk -v begin="$BEGIN_MARKER" -v end="$END_MARKER" '
        $0 == begin { in_block=1; next }
        $0 == end   { in_block=0; next }
        !in_block   { print }
    ' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -vE '^(#|$)' || true
}

for filename in .aiignore .cursorignore .codeiumignore; do
    target="$AIIGNORE_DIR/$filename"

    if [[ -f "$target" ]]; then
        existing_content=$(cat "$target")
    else
        existing_content=""
    fi

    user_patterns=""
    if [[ -f "$target" ]]; then
        user_patterns=$(extract_user_patterns "$target")
    fi
    managed_block=$(build_managed_block "$user_patterns")

    if [[ "$existing_content" == *"$BEGIN_MARKER"* && "$existing_content" == *"$END_MARKER"* ]]; then
        new_content=$(awk -v begin="$BEGIN_MARKER" -v end="$END_MARKER" -v block="$managed_block" '
            $0 == begin { print block; in_block=1; next }
            $0 == end   { in_block=0; next }
            !in_block   { print }
        ' "$target")
    elif [[ -n "$existing_content" ]]; then
        if head -1 "$target" 2>/dev/null | grep -q "Generated by safe-assistant"; then
            new_content="$managed_block"
        else
            new_content="$existing_content"$'\n\n'"$managed_block"
        fi
    else
        new_content="$managed_block"
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would write to $target:"
        echo "$new_content"
        echo ""
        continue
    fi

    if [[ -f "$target" ]] && [[ "$existing_content" == "$new_content" ]]; then
        ok "$filename already in sync"
        continue
    fi

    printf '%s\n' "$new_content" > "$target"
    ok "Updated $target"
done

if [[ "$DRY_RUN" == "true" ]]; then
    echo ""
    info "Dry run - no changes made"
fi
