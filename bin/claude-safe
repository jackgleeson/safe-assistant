#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

# shellcheck source=../lib/check-platform.sh
source "$LIB_DIR/check-platform.sh"
# shellcheck source=../lib/check-hardening.sh
source "$LIB_DIR/check-hardening.sh"
# shellcheck source=../lib/check-sandbox.sh
source "$LIB_DIR/check-sandbox.sh"
# shellcheck source=../lib/check-runner.sh
source "$LIB_DIR/check-runner.sh"

STRICT=false
SKIP_CHECKS=false
USE_RUNNER=true

usage() {
    cat <<EOF
Usage: claude-safe [OPTIONS] [-- CLAUDE_ARGS...]

Security-hardening wrapper for Claude Code.

Verifies OS hardening (ptrace_scope, SIP, sandbox deps), strips sensitive env
vars (SSH_AUTH_SOCK, GPG_AGENT_INFO, DBUS_SESSION_BUS_ADDRESS), then
launches claude - optionally as a separate OS user for isolation.

ISOLATION MODE
  If 'claude-runner' is set up (see bin/setup-claude-runner), claude-safe
  launches Claude as that restricted user instead of as you. That user
  cannot read your home directory - no ~/.ssh keys, ~/.aws credentials,
  browser profiles, etc. It only has access to the project directories
  you've granted (via claude-safe-grant-access). This is a stronger
  boundary than deny rules alone, which rely on the LLM's tool layer.

  Without the runner set up, claude-safe still runs hardening checks
  and strips env vars, but Claude runs as your normal user.

Options:
  --strict        Exit with error on any failed check (default: warn and continue)
  --skip-checks   Skip all hardening checks (just strip env vars and launch)
  --current-user  Launch as the current user, even if claude-runner is available
  -h, --help      Show this help message

Examples:
  claude-safe                          # Use claude-runner if set up, else current user
  claude-safe --current-user           # Run as the current user
  claude-safe --strict
  claude-safe -- --model sonnet
  claude-safe --skip-checks -- -p "explain this code"
EOF
    exit 0
}

# Parse our own flags, stop at -- or first unrecognized arg
CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --strict)    STRICT=true; shift ;;
        --skip-checks) SKIP_CHECKS=true; shift ;;
        --current-user) USE_RUNNER=false; shift ;;
        -h|--help)   usage ;;
        --)          shift; CLAUDE_ARGS+=("$@"); break ;;
        *)           CLAUDE_ARGS+=("$1"); shift ;;
    esac
done

# --- Decide whether to use the runner ---

detect_platform

# Returns 0 if the runner exists and is usable, sets RUNNER_SKIP_REASON otherwise.
# Does NOT check project access - that's handled separately so we can prompt to fix it.
RUNNER_SKIP_REASON=""
_user_exists() {
    case "$SAFE_ASSISTANT_OS" in
        linux) id "$RUNNER_USER" &>/dev/null ;;
        macos) dscl . -read "/Users/$RUNNER_USER" &>/dev/null ;;
        *) return 1 ;;
    esac
}

runner_available() {
    case "$SAFE_ASSISTANT_OS" in
        linux|macos) ;;
        *) RUNNER_SKIP_REASON="unsupported platform"; return 1 ;;
    esac
    if ! _user_exists; then
        RUNNER_SKIP_REASON="$RUNNER_USER user does not exist (run bin/setup-claude-runner)"
        return 1
    fi
    # Passwordless sudo is required for auto mode; without it we'd prompt
    # silently and confuse the user.
    if ! sudo -n -u "$RUNNER_USER" true 2>/dev/null; then
        RUNNER_SKIP_REASON="passwordless sudo to $RUNNER_USER not configured"
        return 1
    fi
    if ! sudo -n -u "$RUNNER_USER" test -f "$RUNNER_HOME_BASE/$RUNNER_USER/.claude/.credentials.json"; then
        RUNNER_SKIP_REASON="$RUNNER_USER has not authenticated Claude Code yet"
        return 1
    fi
    if ! sudo -n -u "$RUNNER_USER" test -x /usr/local/bin/claude 2>/dev/null \
      && ! sudo -n -u "$RUNNER_USER" bash -c 'command -v claude' &>/dev/null; then
        RUNNER_SKIP_REASON="$RUNNER_USER cannot execute claude (run bin/setup-claude-runner)"
        return 1
    fi
    return 0
}

# Returns:
#   0 - has read+write access
#   1 - missing read
#   2 - has read but missing write
runner_project_access() {
    sudo -n -u "$RUNNER_USER" test -r "$PWD" || return 1
    sudo -n -u "$RUNNER_USER" test -w "$PWD" || return 2
    return 0
}

grant_access_prompt() {
    local missing="$1"  # "read" or "write"
    local grant_bin
    grant_bin="$(command -v claude-safe-grant-access || echo "$SCRIPT_DIR/claude-safe-grant-access")"

    warn "$RUNNER_USER has no $missing access to $PWD"
    echo "  Without it, Claude running as $RUNNER_USER cannot $([[ $missing == read ]] && echo 'see' || echo 'edit') files here."
    echo ""
    echo "  This will also chmod o-rwx on every file/dir along the path from"
    echo "  your home down to $PWD, so $RUNNER_USER cannot see anything else."
    echo "  Preview the exact changes with:"
    echo "    claude-safe-grant-access --dry-run $PWD"
    echo ""
    if [[ ! -t 0 ]]; then
        info "Run: claude-safe-grant-access $PWD"
        return 1
    fi
    read -rp "Grant $RUNNER_USER read/write access to $PWD now? [Y/n] " yn
    yn="${yn:-y}"
    if [[ "$yn" =~ ^[Yy] ]]; then
        "$grant_bin" "$PWD" || return 1
        return 0
    fi
    info "Skipped. You can grant later with: claude-safe-grant-access $PWD"
    return 1
}

AS_RUNNER=false
if [[ "$USE_RUNNER" == "true" ]]; then
    if runner_available; then
        access_rc=0
        runner_project_access || access_rc=$?
        case "$access_rc" in
            0) AS_RUNNER=true ;;
            1)
                if grant_access_prompt read; then AS_RUNNER=true; fi
                ;;
            2)
                if grant_access_prompt write; then AS_RUNNER=true; fi
                ;;
        esac

        if [[ "$AS_RUNNER" == "true" ]]; then
            ok "Running Claude isolated under $RUNNER_USER (use --current-user to disable)"
        else
            fail "Aborting: could not run isolated under $RUNNER_USER. Re-run with --current-user to launch without isolation."
        fi
    else
        warn "Isolation unavailable: $RUNNER_SKIP_REASON"
        info "To enable isolation, run: bin/setup-claude-runner"
        fail "Aborting. Re-run with --current-user to launch without isolation."
    fi
fi


if [[ "$SKIP_CHECKS" == "false" ]]; then
    check_hardening "$STRICT"
    check_sandbox_deps "$STRICT"
    if [[ "$AS_RUNNER" == "true" ]]; then
        check_sandbox_enabled "$STRICT" "$RUNNER_HOME_BASE/$RUNNER_USER/.claude/settings.json" "$RUNNER_USER"
    else
        check_sandbox_enabled "$STRICT"
    fi
fi

# --- Strip sensitive env vars ---

unset SSH_AUTH_SOCK 2>/dev/null || true
unset GPG_AGENT_INFO 2>/dev/null || true

if [[ "${SAFE_ASSISTANT_OS:-}" == "linux" ]]; then
    unset DBUS_SESSION_BUS_ADDRESS 2>/dev/null || true
fi

# --- Launch ---

if [[ "$AS_RUNNER" == "true" ]]; then
    # Make it obvious the session is running under an isolated user
    printf '\n\033[1;45;30m  Running Claude Code as %s (isolated from your user)  \033[0m\n\n' "$RUNNER_USER"
    # Set terminal title as a persistent reminder
    printf '\033]0;Claude (as %s)\007' "$RUNNER_USER"

    exec sudo -H -u "$RUNNER_USER" --preserve-env=TERM,COLORTERM,LANG \
        claude "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
else
    if ! command -v claude &>/dev/null; then
        fail "claude not found in PATH"
    fi
    exec claude "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
fi
